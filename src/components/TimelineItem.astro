---
import type { TimelineEntry } from '../data/experience';

export interface Props {
  entry: TimelineEntry;
  isLast?: boolean;
}

const { entry, isLast = false } = Astro.props;
const { role, organization, location, period, bullets, isEducation } = entry;
---

<li class:list={['timeline-item', { 'timeline-item--last': isLast, 'timeline-item--education': isEducation }]}>
  <!-- Vertical spine and dot -->
  <div class="timeline-item__spine" aria-hidden="true">
    <div class="timeline-item__dot"></div>
    {!isLast && <div class="timeline-item__line"></div>}
  </div>

  <!-- Content -->
  <div class="timeline-item__content">
    <div class="timeline-item__header">
      <h3 class="timeline-item__role">{role}</h3>
      <span class="timeline-item__period">{period}</span>
    </div>

    <p class="timeline-item__org">
      {organization}
      {location && <span class="timeline-item__location"> · {location}</span>}
    </p>

    {bullets && bullets.length > 0 && (
      <ul class="timeline-item__bullets" role="list">
        {bullets.map((bullet) => (
          <li class="timeline-item__bullet">{bullet}</li>
        ))}
      </ul>
    )}
  </div>
</li>

<style>
  .timeline-item {
    display: flex;
    gap: var(--space-6);
    padding-bottom: var(--space-8);
  }

  .timeline-item--last {
    padding-bottom: 0;
  }

  /* Spine column */
  .timeline-item__spine {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 20px;
  }

  .timeline-item__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 0 3px var(--color-accent-light);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .timeline-item--education .timeline-item__dot {
    background: #22C55E;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2);
  }

  .timeline-item__line {
    flex: 1;
    width: 2px;
    background: var(--color-border);
    margin-top: var(--space-2);
  }

  /* Content */
  .timeline-item__content {
    flex: 1;
    padding-top: 0;
  }

  .timeline-item__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-1);
  }

  .timeline-item__role {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .timeline-item__period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    padding-top: 2px;
  }

  .timeline-item__org {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .timeline-item__location {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .timeline-item__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .timeline-item__bullet {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-left: var(--space-4);
    position: relative;
  }

  .timeline-item__bullet::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
