---

<footer class="footer" aria-label="Site footer">
  <div class="footer__inner container">
    <div class="footer__main">
      <p class="footer__copy">
        &copy; 2026 Lorenz R. Maray
        <span class="footer__sep" aria-hidden="true"> · </span>
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        <span class="footer__sep" aria-hidden="true"> · </span>
        Hosted on <a href="https://netlify.com" target="_blank" rel="noopener noreferrer">Netlify</a>
      </p>

      <ul class="footer__social" role="list" aria-label="Social links">
        {socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              set:html={link.icon}
            />
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    padding: var(--space-8) var(--space-4);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__copy {
    font-size: 0.875rem;
    color: #64748B;
  }

  .footer__copy a {
    color: #94A3B8;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__copy a:hover {
    color: var(--color-accent);
  }

  .footer__sep {
    color: #334155;
  }

  .footer__social {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #64748B;
    border: 1px solid #1E293B;
    border-radius: 50%;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .footer__social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(37, 99, 235, 0.1);
  }

  @media (max-width: 768px) {
    .footer__main {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
