---

<section class="section contact" id="contact" aria-label="Contact">
  <div class="container">
    <div class="fade-in">
      <h2 class="section-heading">Let's Connect</h2>
      <p class="contact__intro">
        Open to junior developer roles, freelance projects, and collaborations.
      </p>
    </div>

    <div class="contact__layout fade-in">
      <!-- Contact form -->
      <div class="contact__form-wrap">
        <form
          name="contact"
          method="POST"
          netlify
          netlify-honeypot="bot-field"
          class="contact__form"
          aria-label="Contact form"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="contact" />

          <!-- Honeypot (hide from humans, catches bots) -->
          <p class="contact__honeypot" aria-hidden="true">
            <label>
              Don't fill this out if you're human:
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input
              class="form-input"
              type="text"
              id="name"
              name="name"
              placeholder="Your name"
              required
              autocomplete="name"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="your@email.com"
              required
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea
              class="form-input form-textarea"
              id="message"
              name="message"
              placeholder="What would you like to discuss?"
              rows="5"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn btn--submit">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Social / reach-out column -->
      <div class="contact__social-col">
        <p class="contact__social-heading">Or reach me directly</p>
        <ul class="contact__social-list" role="list">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="contact__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
              >
                <span class="contact__social-icon" set:html={link.icon} />
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: var(--space-4);
    margin-bottom: var(--space-8);
    max-width: 480px;
  }

  .contact__layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-12);
    align-items: start;
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact__honeypot {
    display: none !important;
    visibility: hidden;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .form-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: 0.9375rem;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn--submit {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: #FFFFFF;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    align-self: flex-start;
    transition: background var(--transition-base), box-shadow var(--transition-base);
  }

  .btn--submit:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
  }

  /* Social column */
  .contact__social-col {
    padding-top: var(--space-2);
  }

  .contact__social-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .contact__social-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
    word-break: break-all;
  }

  .contact__social-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .contact__social-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .contact__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
