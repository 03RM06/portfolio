---
// Hero section — full viewport, dark background

// Pre-compute the dot grid so the template stays simple
const dots: { cx: number; cy: number }[] = [];
for (let row = 0; row < 8; row++) {
  for (let col = 0; col < 8; col++) {
    dots.push({ cx: col * 40 + 20, cy: row * 40 + 20 });
  }
}
---

<section class="hero" id="hero" aria-label="Introduction">
  <div class="hero__inner container">
    <div class="hero__content">
      <p class="hero__eyebrow">Hi, I'm</p>
      <h1 class="hero__name">Lorenz R. Maray</h1>
      <p class="hero__tagline">
        From leading teams to building software —<br />
        seven years in BPO operations, now writing the code.
      </p>
      <div class="hero__ctas">
        <a href="#projects" class="btn btn--primary">View My Work</a>
      </div>
    </div>

    <!-- Subtle decorative dot-grid + rings -->
    <div class="hero__deco" aria-hidden="true">
      <svg
        width="320"
        height="320"
        viewBox="0 0 320 320"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        {dots.map((d) => (
          <circle cx={d.cx} cy={d.cy} r="2" fill="rgba(37,99,235,0.25)" />
        ))}
        <circle cx="160" cy="160" r="120" stroke="rgba(37,99,235,0.12)" stroke-width="1" fill="none" />
        <circle cx="160" cy="160" r="80"  stroke="rgba(37,99,235,0.18)" stroke-width="1" fill="none" />
      </svg>
    </div>
  </div>

  <!-- Scroll hint -->
  <a href="#about" class="hero__scroll-hint" aria-label="Scroll down to About section">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 5v14M5 12l7 7 7-7" stroke="#94A3B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: var(--color-dark);
    overflow: hidden;
  }

  .hero__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    padding-block: var(--space-24);
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero__content {
    flex: 1;
    max-width: 640px;
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
    letter-spacing: 0.04em;
  }

  .hero__name {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 700;
    color: #F1F5F9;
    line-height: 1.05;
    margin-bottom: var(--space-6);
  }

  .hero__tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: #94A3B8;
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 540px;
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Decorative dot grid */
  .hero__deco {
    flex-shrink: 0;
    opacity: 0.6;
    pointer-events: none;
  }

  /* Scroll hint arrow */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.6;
    transition: opacity var(--transition-base);
    animation: hero-bounce 2s ease-in-out infinite;
  }

  .hero__scroll-hint:hover {
    opacity: 1;
  }

  @keyframes hero-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);   }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-hint { animation: none; }
  }

  @media (max-width: 768px) {
    .hero__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-8);
      padding-block: var(--space-16);
    }

    .hero__deco {
      display: none;
    }
  }
</style>
